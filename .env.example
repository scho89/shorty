# Django
# Choose `local` for local development and `prod` for production settings.
SECRET_KEY=change-this-secret-key
DEBUG=False
# Comma-separated host names served by this app.
ALLOWED_HOSTS=shorty.example.com
# Optional. Leave blank to auto-build from ALLOWED_HOSTS in most cases.
CSRF_TRUSTED_ORIGINS=https://shorty.example.com
DJANGO_SETTINGS_PROFILE=local
# When true in prod, 127.0.0.1 and localhost are also accepted.
ALLOW_LOCAL_HOSTS=False
# Cache lifetime in seconds for dynamic allowed-host refresh.
DYNAMIC_ALLOWED_HOSTS_CACHE_SECONDS=5
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# DNS / domain verification
# CNAME target that branded short-link domains must point to.
CNAME_HOST_TARGET=443.scho.kr
# Optional comma-separated DNS resolvers used for TXT/CNAME checks.
# Leave blank to use the server's system DNS resolver.
DNS_RESOLVER_NAMESERVERS=8.8.8.8,1.1.1.1
# Optional path to a file that stores verified SSL domains.
SSL_LIST=logs/ssl_domains.txt

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@shorty.example.com
# Verification code lifetime in seconds for password/email flows.
ACCOUNT_VERIFICATION_CODE_TTL=600
# Click analytics retention period in days.
CLICK_EVENT_RETENTION_DAYS=14

# Production database settings (used when DJANGO_SETTINGS_PROFILE=prod)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Waitress
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8080
